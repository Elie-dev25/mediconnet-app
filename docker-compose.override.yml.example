# Example docker-compose.override.yml for development
# Copy this file to docker-compose.override.yml and modify as needed

version: '3.8'

services:
  # Expose internal ports for development
  mediconnet-db:
    ports:
      - "3306:3306"

  mediconnet-backend:
    ports:
      - "8080:8080"
      - "8081:8081"

  mediconnet-frontend:
    ports:
      - "4200:80"

  adminer:
    ports:
      - "8888:8080"

  mailhog:
    ports:
      - "1025:1025"
      - "8025:8025"

  # Override Nginx to expose frontend directly (bypass proxy)
  nginx:
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/ssl:/etc/nginx/ssl:ro  # For HTTPS development
