# Mediconnet Production Environment Variables
# Copy to .env.production and fill with REAL values

# Database (Production server)
DB_HOST=mediconnet-db
DB_PORT=3306
DB_NAME=mediconnet_production
DB_USER=mediconnet_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# JWT (Generate strong secrets!)
JWT_SECRET=CHANGE_THIS_32_CHARACTER_MINIMUM_SECRET_KEY_FOR_PRODUCTION
JWT_ISSUER=MediConnect
JWT_AUDIENCE=MediConnectUsers

# Email (Real SMTP server)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USE_SSL=true
EMAIL_SENDER_EMAIL=noreply@mediconnet.com
EMAIL_SENDER_NAME=MediConnect

# URLs (HTTPS en production)
FRONTEND_URL=https://mediconnet.com
API_URL=https://mediconnet.com/api

# Backup settings
BACKUP_DIR=/backups/mediconnet
DB_BACKUP_SCHEDULE=0 2 * * *  # Tous les jours à 2h du matin
